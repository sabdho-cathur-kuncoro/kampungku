// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  KETUA_RT
  BENDAHARA
  SEKRETARIS
  WARGA
}

enum StatusTinggal {
  TETAP
  KONTRAK
  KOST
  PINDAH
}

enum StatusIuran {
  BELUM_BAYAR
  MENUNGGU_VERIFIKASI
  LUNAS
}

enum StatusSurat {
  DIAJUKAN
  DIPROSES
  DISETUJUI
  DITOLAK
}

enum StatusPengaduan {
  BARU
  DIPROSES
  SELESAI
  DITOLAK
}

enum KategoriPengumuman {
  UMUM
  KEGIATAN
  KEUANGAN
  DARURAT
}

enum JenisSurat {
  DOMISILI
  KETERANGAN_TIDAK_MAMPU
  KETERANGAN_USAHA
  PENGANTAR_KTP
  PENGANTAR_KK
  LAINNYA
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id           String    @id @default(uuid())
  tenantId     String?   @map("tenant_id")
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  phone        String?   @db.VarChar(15)
  passwordHash String    @map("password_hash")
  role         Role      @default(WARGA)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant        RT?               @relation(fields: [tenantId], references: [id])
  warga         Warga?
  refreshTokens RefreshToken[]
  pengumuman    Pengumuman[]
  approvedSurat PermohonanSurat[] @relation("ApprovedBy")
  chatSessions  ChatSession[]

  @@index([tenantId])
  @@map("users")
}

model Warga {
  id           String        @id @default(uuid())
  userId       String        @unique @map("user_id")
  nik          String        @db.Char(16)
  noKk         String        @db.Char(16) @map("no_kk")
  alamat       String
  rtId         String        @map("rt_id")
  statusTinggal StatusTinggal @default(TETAP) @map("status_tinggal")
  tglMasuk     DateTime?     @map("tgl_masuk") @db.Date
  fotoProfilUrl String?      @map("foto_profil_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id])
  rt               RT                 @relation(fields: [rtId], references: [id])
  anggotaKeluarga  AnggotaKeluarga[]
  iuranTagihan     IuranTagihan[]
  permohonanSurat  PermohonanSurat[]
  pengaduan        Pengaduan[]

  @@unique([rtId, nik])
  @@index([rtId])
  @@map("warga")
}

model AnggotaKeluarga {
  id         String   @id @default(uuid())
  wargaId    String   @map("warga_id")
  nama       String   @db.VarChar(100)
  nik        String   @db.Char(16)
  hubungan   String   @db.VarChar(30)
  tglLahir   DateTime @map("tgl_lahir") @db.Date
  jenisKelamin String @map("jenis_kelamin") @db.VarChar(10)
  pekerjaan  String?  @db.VarChar(100)
  pendidikan String?  @db.VarChar(50)

  warga Warga @relation(fields: [wargaId], references: [id], onDelete: Cascade)

  @@map("anggota_keluarga")
}

// RT = entitas tenant. Satu RT = satu tenant.
model RT {
  id        String   @id @default(uuid())
  nama      String   @db.VarChar(150)
  slug      String   @unique @db.VarChar(80)
  nomorRt   String   @map("nomor_rt") @db.VarChar(5)
  nomorRw   String   @map("nomor_rw") @db.VarChar(5)
  kelurahan String   @db.VarChar(100)
  kecamatan String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  warga           Warga[]
  iuranTagihan    IuranTagihan[]
  pengumuman      Pengumuman[]
  jenisIuran      JenisIuran[]
  permohonanSurat PermohonanSurat[]
  pengaduan       Pengaduan[]
  refreshTokens   RefreshToken[]
  chatSessions    ChatSession[]

  @@map("rt_rw")
}

model JenisIuran {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  nama        String  @db.VarChar(100)
  jumlah      Decimal @db.Decimal(10, 2)
  keterangan  String?
  isAktif     Boolean @default(true) @map("is_aktif")

  tenant       RT             @relation(fields: [tenantId], references: [id])
  iuranTagihan IuranTagihan[]

  @@unique([tenantId, nama])
  @@index([tenantId])
  @@map("jenis_iuran")
}

model IuranTagihan {
  id           String      @id @default(uuid())
  wargaId      String      @map("warga_id")
  jenisIuranId String      @map("jenis_iuran_id")
  rtId         String      @map("rt_id")
  bulan        Int
  tahun        Int
  jumlah       Decimal     @db.Decimal(10, 2)
  status       StatusIuran @default(BELUM_BAYAR)
  tglBayar     DateTime?   @map("tgl_bayar")
  verifiedBy   String?     @map("verified_by")
  catatan      String?
  createdAt    DateTime    @default(now()) @map("created_at")

  warga      Warga      @relation(fields: [wargaId], references: [id])
  jenisIuran JenisIuran @relation(fields: [jenisIuranId], references: [id])
  rt         RT         @relation(fields: [rtId], references: [id])

  @@unique([wargaId, jenisIuranId, bulan, tahun])
  @@map("iuran_tagihan")
}

model Pengumuman {
  id         String               @id @default(uuid())
  judul      String               @db.VarChar(200)
  konten     String
  kategori   KategoriPengumuman   @default(UMUM)
  authorId   String               @map("author_id")
  rtId       String               @map("rt_id")
  tglMulai   DateTime             @map("tgl_mulai")
  tglSelesai DateTime?            @map("tgl_selesai")
  isPinned   Boolean              @default(false) @map("is_pinned")
  createdAt  DateTime             @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [id])
  rt     RT   @relation(fields: [rtId], references: [id])

  @@map("pengumuman")
}

model PermohonanSurat {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  wargaId     String      @map("warga_id")
  jenisSurat  JenisSurat  @map("jenis_surat")
  keperluan   String
  status      StatusSurat @default(DIAJUKAN)
  noSurat     String?     @unique @map("no_surat")
  approvedBy  String?     @map("approved_by")
  alasanTolak String?     @map("alasan_tolak")
  tglDiajukan DateTime    @default(now()) @map("tgl_diajukan")
  tglDiproses DateTime?   @map("tgl_diproses")

  tenant   RT    @relation(fields: [tenantId], references: [id])
  warga    Warga @relation(fields: [wargaId], references: [id])
  approver User? @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@index([tenantId])
  @@map("permohonan_surat")
}

model Pengaduan {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  wargaId     String?         @map("warga_id")
  judul       String          @db.VarChar(200)
  deskripsi   String
  isAnonim    Boolean         @default(false) @map("is_anonim")
  status      StatusPengaduan @default(BARU)
  tanggapan   String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant RT     @relation(fields: [tenantId], references: [id])
  warga  Warga? @relation(fields: [wargaId], references: [id])

  @@index([tenantId])
  @@map("pengaduan")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String?  @map("tenant_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant RT?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("refresh_tokens")
}

model ChatSession {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  tenantId  String      @map("tenant_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   RT            @relation(fields: [tenantId], references: [id])
  messages ChatMessage[]

  @@index([userId, tenantId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      MessageRole
  content   String
  createdAt DateTime    @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}
